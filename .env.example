# Variáveis de ambiente da aplicação.
# Copie para .env.dev (desenvolvimento) ou .env.prod (produção) e ajuste os valores.
#
# Desenvolvimento:  cp .env.example .env.dev
# Produção:         cp .env.example .env.prod  (nunca versionar .env.prod)

DB_HOST=db
DB_PORT=5432
DB_HOST_PORT=5432
DB_NAME=carlesso_pilates
DB_USER=postgres
DB_PASSWORD=postgres

# Obrigatório — use pelo menos 32 caracteres. Em produção, use 64+.
JWT_SECRET=replace_with_a_secret_with_at_least_32_characters
JWT_EXPIRATION_MS=86400000

# Em produção, substitua pelo domínio real do frontend.
CORS_ALLOWED_ORIGINS=http://localhost:4200

# Obrigatório em produção quando ainda não existe ADMIN ativo.
APP_INITIAL_ADMIN_EMAIL=admin@carlessopilates.com
APP_INITIAL_ADMIN_PASSWORD=

APP_COBRANCA_CRON_VENCIDOS=0 0 6 * * *
APP_COBRANCA_CRON_COBRANCAS_FUTURAS=0 0 7 * * *
APP_COBRANCA_VENCIMENTO_DIAS=10
APP_PAGINACAO_TAMANHO_PADRAO=10

# E-mail transacional (recuperação de senha). Sem SMTP_HOST configurado,
# o envio de e-mail falha — obrigatório em produção para /auth/forgot-password.
# Em desenvolvimento, aponte para um SMTP local (ex.: Mailpit/MailHog em localhost:1025).
APP_EMAIL_PROVIDER=smtp
APP_EMAIL_FROM=no-reply@carlessopilates.com.br
# URL do frontend para onde o link de redefinição aponta (?token=...).
APP_EMAIL_RESET_PASSWORD_URL=https://app.carlessopilates.com.br/resetar-senha
APP_EMAIL_RESET_PASSWORD_TOKEN_TTL_MINUTOS=30
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=

# Recursos do container da aplicação.
# APP_MEM_LIMIT limita a memória do container (a heap da JVM usa 75% desse valor).
# JAVA_OPTS sobrescreve as flags da JVM — o valor substitui o padrão por completo,
# então inclua -XX:MaxRAMPercentage (ou -Xmx) ao customizar.
APP_MEM_LIMIT=1g
JAVA_OPTS=-XX:MaxRAMPercentage=75.0
